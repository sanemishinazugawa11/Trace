{
  "expo": {
    "name": "Trace",
    "slug": "Trace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trace",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "android": {
      "newArchEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.sanemishinazugawa.Trace"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "47f39066-4b01-41a4-9f31-2851e6ecc89f"
      }
    }
  }
}